# Google AdSense (optional — ads show when client ID is set)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Default slot used for all placements if specific slots are not set
NEXT_PUBLIC_ADSENSE_SLOT=1234567890
# Optional: separate ad units per placement (create in AdSense dashboard)
# NEXT_PUBLIC_ADSENSE_SLOT_HORIZONTAL=
# NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Site URL (sitemap, canonical URLs, Open Graph — production must use www)
# Production: https://www.schoolhomeworkhelper.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Editorial identity (optional — shown only when a real public identity is supplied)
# EDITORIAL_OWNER_NAME=
# EDITORIAL_OWNER_CREDENTIALS=

# Contact form email delivery (Resend)
# Verify schoolhomeworkhelper.com in Resend before using a domain sender.
RESEND_API_KEY=re_xxxxxxxxx
CONTACT_FROM_EMAIL="School Homework Helper <contact@schoolhomeworkhelper.com>"
CONTACT_TO_EMAIL=hello@schoolhomeworkhelper.com

# Google Analytics 4 (optional — traffic stats + Search Console GA verification)
# Create at https://analytics.google.com → Admin → Data streams → Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BRSQJZ50RX

# OpenAI (required for AI tools)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
# Optional: OpenAI text-to-speech fallback (Listen Audio button)
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=nova

# Optional: YouTube Data API for School Projects tutorial video thumbnails (search)
# YOUTUBE_API_KEY=your-youtube-api-key

# Supports: en-IN, hi-IN, bn-IN, ta-IN, te-IN, kn-IN, ml-IN, mr-IN, gu-IN, pa-IN, od-IN
# Get a key at https://dashboard.sarvam.ai
SARVAM_API_KEY=your-sarvam-api-key
# Optional Sarvam voice overrides per language (see dashboard.sarvam.ai)
# SARVAM_ENGLISH_SPEAKER=ratan
# SARVAM_HINDI_SPEAKER=shubh
# SARVAM_PUNJABI_SPEAKER=ritu
# SARVAM_TAMIL_SPEAKER=vignesh
# SARVAM_TELUGU_SPEAKER=sindhu
# SARVAM_BENGALI_SPEAKER=meera
# SARVAM_MARATHI_SPEAKER=shubh
# SARVAM_GUJARATI_SPEAKER=priya
# SARVAM_KANNADA_SPEAKER=aditya
# SARVAM_MALAYALAM_SPEAKER=mohan
# SARVAM_ODIA_SPEAKER=prasant

# Supabase (required for Google sign-in + optional AI request logging)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Dashboard → Authentication → URL Configuration (required for sign-in):
# Site URL: https://www.yourdomain.com  (must include https:// — NOT just yourdomain.com)
# Redirect URLs (add all that apply):
#   https://www.yourdomain.com/**
#   https://yourdomain.com/**
#   http://localhost:3000/**
# Google OAuth: Authentication → Providers → Google (enable + add Client ID/Secret)

# Google AdSense CMP (Privacy & messaging → European regulations, Option 2):
# After enabling Google's certified CMP in AdSense, the site loads Consent Mode v2
# and shows Google's message in the EEA/UK/CH. Our banner handles other regions.
